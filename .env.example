FLUX_MCP_PROFILES_ACTIVE=dev
FLUX_MCP_SERVER_PORT=8092

FLUX_MCP_R2DBC_URL=r2dbc:postgresql://localhost:5442/ai_rag_platform?schema=flux_mcp
FLUX_MCP_JDBC_URL=jdbc:postgresql://localhost:5442/ai_rag_platform
FLUX_MCP_DB_USERNAME=postgres
FLUX_MCP_DB_PASSWORD=123456

FLUX_MCP_SESSION_STORE_TYPE=memory
FLUX_MCP_SESSION_TTL=PT30M
FLUX_MCP_SESSION_CLEANUP_INTERVAL=PT5M

FLUX_MCP_REDIS_HOST=localhost
FLUX_MCP_REDIS_PORT=6379
FLUX_MCP_REDIS_PASSWORD=

FLUX_MCP_SSE_PATH=/sse
FLUX_MCP_STREAMABLE_HTTP_PATH=/mcp/message

FLUX_MCP_HEALTH_ENABLED=true
FLUX_MCP_HEALTH_INTERVAL=PT60S
FLUX_MCP_HEALTH_TIMEOUT=PT5S
FLUX_MCP_HEALTH_SLOW_THRESHOLD=PT3S
FLUX_MCP_HEALTH_MAX_FAILURES=5
FLUX_MCP_HEALTH_AUTO_DEACTIVATE=true
FLUX_MCP_HEALTH_CONCURRENCY=5