MCP_GATEWAY_PROFILES_ACTIVE=dev
MCP_GATEWAY_SERVER_PORT=8092

MCP_GATEWAY_R2DBC_URL=r2dbc:postgresql://localhost:5442/ai_rag_platform?schema=mcp_gateway
MCP_GATEWAY_JDBC_URL=jdbc:postgresql://localhost:5442/ai_rag_platform
MCP_GATEWAY_DB_USERNAME=postgres
MCP_GATEWAY_DB_PASSWORD=123456

MCP_GATEWAY_SESSION_STORE_TYPE=memory
MCP_GATEWAY_SESSION_TTL=PT30M
MCP_GATEWAY_SESSION_CLEANUP_INTERVAL=PT5M

MCP_GATEWAY_REDIS_HOST=localhost
MCP_GATEWAY_REDIS_PORT=6379
MCP_GATEWAY_REDIS_PASSWORD=

MCP_GATEWAY_SSE_PATH=/sse
MCP_GATEWAY_STREAMABLE_HTTP_PATH=/mcp/message

MCP_GATEWAY_HEALTH_ENABLED=true
MCP_GATEWAY_HEALTH_INTERVAL=PT60S
MCP_GATEWAY_HEALTH_TIMEOUT=PT5S
MCP_GATEWAY_HEALTH_SLOW_THRESHOLD=PT3S
MCP_GATEWAY_HEALTH_MAX_FAILURES=5
MCP_GATEWAY_HEALTH_AUTO_DEACTIVATE=true
MCP_GATEWAY_HEALTH_CONCURRENCY=5