{
  "properties": [
    {
      "name": "redis.sdk.config.host",
      "type": "java.lang.String",
      "description": "Redisson server host."
    },
    {
      "name": "redis.sdk.config.port",
      "type": "java.lang.Integer",
      "description": "Redisson server port."
    },
    {
      "name": "redis.sdk.config.password",
      "type": "java.lang.String",
      "description": "Redisson server password."
    },
    {
      "name": "app.mcp.sse-path",
      "type": "java.lang.String",
      "description": "SSE endpoint path for the MCP server."
    },
    {
